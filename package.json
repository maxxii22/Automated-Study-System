{
  "name": "automated-study-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "postinstall": "npm run prisma:generate --workspace server",
    "start": "concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:client\"",
    "dev": "npm run dev --workspace client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:worker": "npm run dev:worker --workspace server",
    "build": "npm run build --workspace shared && npm run build --workspace server && npm run build --workspace client",
    "test:load": "node scripts/load-study-generation.mjs",
    "test:queue": "node scripts/queue-failure-drill.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
